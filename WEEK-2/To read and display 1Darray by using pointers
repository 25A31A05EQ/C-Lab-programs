#include <iostream>
using namespace std;

int main()
{
    int n, i;
    int arr[100];
    int *ptr;

    cout << "Enter number of elements: ";
    cin >> n;

    ptr = arr;   // pointer pointing to first element of array

    cout << "Enter " << n << " elements:\n";
    for(i = 0; i < n; i++)
    {
        cin >> *(ptr + i);   // reading elements using pointer
    }

    cout << "Array elements are:\n";
    for(i = 0; i < n; i++)
    {
        cout << *(ptr + i) << " ";   // displaying elements using pointer
    }

    return 0;
}
