#include <iostream>
using namespace std;

int main()
{
    int n, i;
    int *arr;

    cout << "Enter number of elements: ";
    cin >> n;

    // Dynamic memory allocation
    arr = new int[n];

    cout << "Enter " << n << " elements:\n";
    for(i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    cout << "The array elements are:\n";
    for(i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }

    // Free allocated memory
    delete[] arr;

    return 0;
}
