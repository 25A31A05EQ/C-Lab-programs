#include <iostream>
using namespace std;

int main()
{
    int n, i;
    int arr[100];

    cout << "Enter number of elements: ";
    cin >> n;

    cout << "Enter " << n << " elements:\n";
    for(i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    cout << "The elements in the array are:\n";
    for(i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }

    return 0;
}
