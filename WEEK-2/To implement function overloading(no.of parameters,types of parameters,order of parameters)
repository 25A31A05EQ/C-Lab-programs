//NO.OF PARAMETERS
#include <iostream>
using namespace std;

void sum(int a, int b)
{
    cout << "Sum of two numbers = " << a + b << endl;
}

void sum(int a, int b, int c)
{
    cout << "Sum of three numbers = " << a + b + c << endl;
}

int main()
{
    sum(5, 10);
    sum(5, 10, 15);
    return 0
}
}

//TYPE OF PARAMETERS
#include <iostream>
using namespace std;

void display(int a)
{
    cout << "Integer value: " << a << endl;
}

void display(float a)
{
    cout << "Float value: " << a << endl;
}

int main()
{
    display(10);
    display(5.5f);
    return 0;
}
//ORDER OF PARAMETERS
#include <iostream>
using namespace std;

void show(int a, float b)
{
    cout << "Integer: " << a << " Float: " << b << endl;
}

void show(float a, int b)
{
    cout << "Float: " << a << " Integer: " << b << endl;
}

int main()
{
    show(10, 5.5);
    show(5.5, 10);
    return 0;
}
