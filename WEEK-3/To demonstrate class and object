#include <iostream>
using namespace std;

class Student
{
public:
    int roll;
    string name;

    void getData()
    {
        cout << "Enter Roll Number: ";
        cin >> roll;
        cout << "Enter Name: ";
        cin >> name;
    }

    void displayData()
    {
        cout << "Roll Number: " << roll << endl;
        cout << "Name: " << name << endl;
    }
};

int main()
{
    Student s1;   // object of class Student

    s1.getData();      // calling member function
    s1.displayData();  // displaying data

    return 0;
}
