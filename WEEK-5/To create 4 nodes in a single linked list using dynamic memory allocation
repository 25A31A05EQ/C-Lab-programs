#include <iostream>
using namespace std;

struct node
{
    int data;
    node *next;
};

int main()
{
    node *n1, *n2, *n3, *n4;

    n1 = new node();
    n2 = new node();
    n3 = new node();
    n4 = new node();

    n1->data = 10;
    n1->next = n2;

    n2->data = 20;
    n2->next = n3;

    n3->data = 30;
    n3->next = n4;

    n4->data = 40;
    n4->next = NULL;

    node *temp = n1;

    while(temp != NULL)
    {
        cout << temp->data << " ";
        temp = temp->next;
    }

    return 0;
}
